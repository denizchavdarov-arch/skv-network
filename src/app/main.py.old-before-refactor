@app.post("/api/v2/entries")
async def create_full_entry(request: Request):
    """Full format: project + cubes + persona in one JSON."""
    raw = await request.json()
    entry_id = str(uuid.uuid4())[:12]
    delete_token = f"skv_del_{uuid.uuid4().hex[:24]}"
    saved = []
    
    # Main entry
    cube_id = raw.get("cube_id", entry_id)
    entries_db[entry_id] = {"id": entry_id, "cube_id": cube_id, "created_at": datetime.utcnow().isoformat(), "raw": raw}
    cubes_library[cube_id] = {"cube_id": cube_id, "title": raw.get("title", "Cube"), "type": raw.get("type", "basic"), "triggers": raw.get("trigger_intent", []), "rules": raw.get("rules", [])}
    delete_tokens[delete_token] = entry_id
    saved.append(cube_id)
    
    # Process cubes
    for ec in raw.get("cubes", []):
        ec_id = ec.get("cube_id", str(uuid.uuid4())[:12])
        cubes_library[ec_id] = {"cube_id": ec_id, "title": ec.get("title", "Cube"), "type": "experience", "triggers": ec.get("trigger_intent", []), "rules": ec.get("rules", [])}
        saved.append(ec_id)
    
    # Process persona
    persona = raw.get("persona", {})
    if persona:
        pid = f"persona_{persona.get('user_id', entry_id)}"
        cubes_library[pid] = {"cube_id": pid, "title": f"Profile - {persona.get('user_id','?')}", "type": "persona", "triggers": [], "rules": [json.dumps(persona, ensure_ascii=False)], "private": True}
        saved.append(pid)
    
    return {"id": entry_id, "public_url": f"/entry/{entry_id}", "delete_token": delete_token, "saved": len(saved), "cubes": saved}

