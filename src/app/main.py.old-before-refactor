@app.get("/api/cubes/search")
async def search_cubes(query: str):
    """Semantic search via Qdrant + Polza embeddings."""
    try:
        from qdrant_client import QdrantClient
        import urllib.request as _req
        
        POLZA_KEY = "pza_LjwfFSaGiO54TOspk13LNRyXA_xhufNR"
        
        # Get embedding
        body = json.dumps({"model": "text-embedding-3-small", "input": query}).encode()
        req = _req.Request("https://api.polza.ai/v1/embeddings", data=body, headers={
            "Content-Type": "application/json",
            "Authorization": f"Bearer {POLZA_KEY}"
        })
        resp = _req.urlopen(req, timeout=15)
        vector = json.loads(resp.read())["data"][0]["embedding"]
        
        # Search in Qdrant
        client = QdrantClient(host="skv_qdrant", port=6333)
        results = client.query_points(collection_name="skv_cubes_v2", query=vector, limit=10)
        
        # Format response
        items = []
        for r in results.points:
            items.append({
                "cube_id": r.payload.get("cube_id", ""),
                "title": r.payload.get("title", ""),
                "score": round(r.score, 3)
            })
        
        return {"results": items, "count": len(items), "query": query, "search_type": "semantic"}
    
    except Exception as e:
        # Fallback to simple search
        q = query.lower()
        results = []
        for cid, c in cubes_library.items():
            title = str(c.get("title", "")).lower()
            triggers = " ".join(c.get("triggers", [])).lower()
            if q in title or q in triggers:
                results.append({"cube_id": cid, "title": c.get("title"), "type": c.get("type", "basic")})
        return {"results": results, "count": len(results), "query": query, "search_type": "fallback"}

