    delete_tokens[delete_token] = entry_id
    # Process embedded cubes
    cube_data = entry_data.get("user_fields", {})
    for ec in cube_data.get("cubes", []):
        ec_id = ec.get("cube_id", str(uuid.uuid4())[:12])
        cubes_library[ec_id] = {"cube_id": ec_id, "title": ec.get("title", "Cube"), "type": "experience", "triggers": ec.get("trigger_intent", []), "rules": ec.get("rules", [])}
        print(f"Cube added to library: {ec_id}")
    # Process persona
    persona = cube_data.get("persona", {})
    if persona:
        pid = f"persona_{persona.get('user_id', entry_id)}"
        cubes_library[pid] = {"cube_id": pid, "title": f"Profile - {persona.get('user_id','?')}", "type": "persona", "triggers": [], "rules": [json.dumps(persona, ensure_ascii=False)], "private": True}
        print(f"Persona added to library: {pid}")
    
    # Save to PostgreSQL (sync, in thread)
    try:
        import threading, asyncpg as _apg
        def _save_sync():
            import asyncio
            async def _do():
                conn = await _apg.connect("postgresql://skv_user:skv_secret_2026@skv_postgres:5432/skv_db")
