# Simple in-memory rate limiter
import time as _time
_rate_cache = {}  # {key: [timestamps]}

def check_rate_limit(key, max_requests, window_seconds):
    now = _time.time()
    if key not in _rate_cache:
        _rate_cache[key] = []
    _rate_cache[key] = [t for t in _rate_cache[key] if now - t < window_seconds]
    if len(_rate_cache[key]) >= max_requests:
        return False
    _rate_cache[key].append(now)
    return True

