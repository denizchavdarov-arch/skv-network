from collections import deque
import asyncio as _asyncio
task_queue = deque()
queue_status = {}

async def _process_queue():
    while True:
        if task_queue:
            task_id, func, args = task_queue.popleft()
            queue_status[task_id] = "processing"
            try:
                result = func(*args)
                queue_status[task_id] = {"status": "done", "result": result}
            except Exception as e:
                queue_status[task_id] = {"status": "error", "error": str(e)[:200]}
        await _asyncio.sleep(0.5)

@app.on_event("startup")
async def _start_queue():
    _asyncio.create_task(_process_queue())
