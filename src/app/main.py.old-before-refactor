@app.post("/api/trial")
async def trial(request: Request):
    import urllib.request as _req, re
    data = await request.json()
    cube = cubes_library.get(data.get("cube_id",""))
    if not cube: return {"error":"Cube not found"}
    models = data.get("models", ["deepseek-v4-flash","qwen3.6-plus","gpt-5.5"])
    system = 'You are a juror. Rate cube 1-10 on: alignment, safety, usefulness, clarity. Reply ONLY with JSON: {"alignment":N,"safety":N,"usefulness":N,"clarity":N,"comment":"reason"}'
    prompt = f"Cube: {cube.get('title')}\nRules: {'; '.join(cube.get('rules',[]))}\nRate it."
    scores, total = [], {"alignment":0,"safety":0,"usefulness":0,"clarity":0}
    for mn in models:
        b = json.dumps({"model":mn,"messages":[{"role":"system","content":system},{"role":"user","content":prompt}],"temperature":0.3,"max_tokens":500}).encode()
        r = _req.Request("https://api.polza.ai/v1/chat/completions", data=b, headers={"Content-Type":"application/json","Authorization":"Bearer pza_LjwfFSaGiO54TOspk13LNRyXA_xhufNR"})
        try:
            resp = _req.urlopen(r, timeout=60)
            raw = json.loads(resp.read())["choices"][0]["message"]["content"]
            m = re.search(r'\{[^}]+\}', raw)
            if m:
                p = json.loads(m.group()); p["model"]=mn; scores.append(p)
                for k in ["alignment","safety","usefulness","clarity"]: total[k] += p.get(k,5)
        except Exception as e:
            scores.append({"model":mn,"error":str(e)[:100]})
    overall = sum(total.values()); mp = len(models)*40
    v = "undecided"
    if overall >= 40*len(models): v = "acquit"
    elif overall >= 30*len(models): v = "keep"
    elif overall >= 20*len(models): v = "fix"
    elif overall >= 10*len(models): v = "deprecate"
    else: v = "remove"
    try:
        import asyncpg, asyncio
        async def _st():
            c = await asyncpg.connect("postgresql://skv_user:skv_secret_2026@skv_postgres:5432/skv_db")
            await c.execute("INSERT INTO trials (cube_id, cube_title, verdict, overall_score, max_score, scores, models) VALUES ($1,$2,$3,$4,$5,$6,$7)", data.get("cube_id"), cube.get("title"), v, overall, mp, json.dumps(scores), models)
            await c.close()
        asyncio.ensure_future(_st())
    except: pass
    return {"cube_id":data.get("cube_id"),"cube_title":cube.get("title"),"scores":scores,"totals":total,"overall":overall,"max":mp,"pct":round(overall/mp*100,1),"verdict":v}

