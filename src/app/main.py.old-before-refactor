@app.get("/api/trials/export")
async def export_trials(cube_id: str = "", verdict: str = "", limit: int = 20, date_from: str = "", date_to: str = ""):
    try:
        import asyncpg
        conn = await asyncpg.connect("postgresql://skv_user:skv_secret_2026@skv_postgres:5432/skv_db")
        q = "SELECT * FROM trials WHERE 1=1"; params = []
        if cube_id: params.append(cube_id); q += f" AND cube_id=${len(params)}"
        if verdict: params.append(verdict); q += f" AND verdict=${len(params)}"
        if date_from: params.append(date_from); q += f" AND created_at>=${len(params)}"
        if date_to: params.append(date_to); q += f" AND created_at<=${len(params)}"
        q += f" ORDER BY created_at DESC LIMIT {int(limit)}"
        rows = await conn.fetch(q, *params); await conn.close()
        return {"count": len(rows), "trials": [{"id":r["id"],"cube_id":r["cube_id"],"cube_title":r["cube_title"],"verdict":r["verdict"],"overall_score":r["overall_score"],"max_score":r["max_score"],"scores":json.loads(r["scores"]) if isinstance(r["scores"],str) else r["scores"],"created_at":str(r["created_at"])} for r in rows]}
    except Exception as e: return {"error": str(e)[:200], "trials": []}


