@app.post("/api/tools/generate")
async def generate_files(request: Request):
    client_ip = request.client.host
    if not check_rate_limit(f"tools_{client_ip}", 5, 60):
        raise HTTPException(429, "Too many requests. Try again later.")
    """Generate output files from anketa."""
    import io, uuid as _uuid, zipfile, os
    data = await request.json()
    outputs = data.get("outputs", ["pdf"])
    files = []
    
    if "pdf" in outputs:
        try:
            from reportlab.lib.pagesizes import A4
            from reportlab.lib.styles import getSampleStyleSheet
            from reportlab.platypus import SimpleDocTemplate, Paragraph, Spacer
            
            buf = io.BytesIO()
            doc = SimpleDocTemplate(buf, pagesize=A4)
            styles = getSampleStyleSheet()
            story = [Paragraph(f"<b>{data.get('title','Report')}</b>", styles["Title"]), Spacer(1, 20)]
            for r in data.get("rules", [])[:20]:
                story.append(Paragraph(f"• {r}", styles["BodyText"]))
            doc.build(story)
            buf.seek(0)
            pdfname = f"{data.get('cube_id','report')}.pdf"
            with open(f"/app/uploads/{pdfname}", "wb") as pf:
                pf.write(buf.read())
            files.append({"type":"pdf","url":f"/download/{pdfname}"})
        except Exception as e:
            files.append({"error":f"PDF: {str(e)[:50]}"})
    
    if "chart" in outputs:
        try:
            import matplotlib.pyplot as plt
            cc = data.get("chart_config", {})
            labels = cc.get("labels", ["A","B","C"])
            values = cc.get("values", [10,20,30])
            plt.figure(figsize=(8,4))
            plt.bar(labels, values, color="#6366f1")
            plt.title(data.get("title","Chart"))
            chartname = f"{data.get('cube_id','chart')}.png"
            plt.savefig(f"/app/uploads/{chartname}", dpi=100, bbox_inches="tight")
            plt.close()
            files.append({"type":"png","url":f"/download/{chartname}"})
        except Exception as e:
            files.append({"error":f"Chart: {str(e)[:50]}"})
    
    if "code" in outputs:
        try:
            cc = data.get("code_config", {})
            lang = cc.get("language","python")
            ext = {"python":"py","javascript":"js","sql":"sql"}.get(lang,"txt")
            code = f"# Generated by SKV Network\n# {data.get('title','')}\n\ndef main():\n    pass\n"
            codename = f"{data.get('cube_id','code')}.{ext}"
            with open(f"/app/uploads/{codename}", "w") as cf:
                cf.write(code)
            files.append({"type":ext,"url":f"/download/{codename}"})
        except Exception as e:
            files.append({"error":f"Code: {str(e)[:50]}"})
    
    if len(files) > 1:
        zipname = f"{data.get('cube_id','output')}.zip"
        with zipfile.ZipFile(f"/app/uploads/{zipname}", "w") as zf:
            for f in files:
                if "url" in f:
                    zf.write(f"/app/uploads/{f['url'].split('/')[-1]}", f["url"].split("/")[-1])
        files.insert(0, {"type":"zip","url":f"/download/{zipname}"})
    
    return {"status":"ok","files":files}

@app.get("/download/{filename}")
async def download_file(filename: str):
    """Download generated files."""
    from fastapi.responses import FileResponse
    import os
    path = f"/app/uploads/{filename}"
    if os.path.exists(path):
        return FileResponse(path, filename=filename)
    raise HTTPException(404, "File not found")

