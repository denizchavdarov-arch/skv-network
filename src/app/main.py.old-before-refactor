                    await conn.execute("INSERT INTO cubes (cube_id, type, title, trigger_intent, rules) VALUES ($1,$2,$3,$4,$5) ON CONFLICT (cube_id) DO UPDATE SET title=$3, trigger_intent=$4, rules=$5", ec.get("cube_id"), "experience", ec.get("title","Cube"), json.dumps(ec.get("trigger_intent",[])), json.dumps(ec.get("rules",[])))
                persona = cube_data.get("persona", {})
                if persona:
                    pid = f"persona_{persona.get('user_id', entry_id)}"
                    await conn.execute("INSERT INTO cubes (cube_id, type, title, trigger_intent, rules) VALUES ($1,$2,$3,$4,$5) ON CONFLICT (cube_id) DO UPDATE SET title=$3, trigger_intent=$4, rules=$5", pid, "persona", f"Profile - {persona.get('user_id','?')}", "[]", json.dumps([json.dumps(persona, ensure_ascii=False)]))
                await conn.close()
            asyncio.run(_do())
        threading.Thread(target=_save_sync, daemon=True).start()
    except Exception as e:
        print(f"DB save error: {e}")
    
    # Auto-index in Qdrant (async, don't block response)
    try:
        import asyncio, threading
        def _index_async():
            try:
                import urllib.request as _req
                from qdrant_client import QdrantClient
                from qdrant_client.models import PointStruct
                POLZA_KEY = "pza_LjwfFSaGiO54TOspk13LNRyXA_xhufNR"
                client = QdrantClient(host="skv_qdrant", port=6333)
                
