</style></head>
<body><div class="c"><a href="/" class="back">Back to SKV</a><h1>Trial Journal</h1>
<div class="stats" id="stats"></div>
<div class="exp"><a href="/api/trials/export?limit=100">All (JSON)</a><a href="/api/trials/export?limit=20">Last 20</a><a href="/api/trials/export?verdict=fix">Only Fix</a><a href="/api/trials/export?verdict=remove">Only Remove</a></div>
<div class="f"><input type="text" id="cid" placeholder="Cube ID"><select id="vsel"><option value="">All verdicts</option><option>acquit</option><option>keep</option><option>fix</option><option>deprecate</option><option>remove</option></select><input type="date" id="df"><input type="date" id="dt"><button onclick="lt()">Filter</button></div>
<div id="r"></div></div>
<script>
async function lt(){
var c=document.getElementById('cid').value;var v=document.getElementById('vsel').value;
var f=document.getElementById('df').value;var t=document.getElementById('dt').value;
var p=new URLSearchParams({limit:50});if(c)p.set('cube_id',c);if(v)p.set('verdict',v);
if(f)p.set('date_from',f);if(t)p.set('date_to',t);
var r=await fetch('/api/trials/export?'+p);var d=await r.json();
var div=document.getElementById('r');
if(!d.trials||d.trials.length===0){div.innerHTML='<p style="color:#888;text-align:center;padding:40px">No trials found</p>';return}
var counts={};
for(var i=0;i<d.trials.length;i++){var vv=d.trials[i].verdict;counts[vv]=(counts[vv]||0)+1}
var st=document.getElementById('stats');
st.innerHTML='<div class="stat"><div class="num">'+d.trials.length+'</div><div class="lbl">Total</div></div>';
var icons={acquit:'OK',keep:'Keep',fix:'Fix',deprecate:'Depr',remove:'Rem'};
for(var k in counts){st.innerHTML+='<div class="stat"><div class="num">'+counts[k]+'</div><div class="lbl">'+k+'</div></div>'}
div.innerHTML=d.trials.map(function(t){var vc='v'+t.verdict;
return '<div class="card"><h3>'+t.cube_title+'</h3><div class="meta">'+t.cube_id+' &middot; '+t.created_at+' &middot; Score: '+t.overall_score+'/'+t.max_score+'</div><span class="v '+vc+'">'+t.verdict.toUpperCase()+'</span>'+t.scores.map(function(s){return '<div class="jur"><b>'+(s.model||'?')+'</b>: A'+(s.alignment||'?')+' S'+(s.safety||'?')+' U'+(s.usefulness||'?')+' C'+(s.clarity||'?')+' &mdash; '+(s.comment||'')+'</div>'}).join('')+'</div>'}).join('');
}
lt();
</script></body></html>""")


