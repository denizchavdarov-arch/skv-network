import os
import uuid
import json
from datetime import datetime
from typing import Optional

from fastapi import FastAPI, HTTPException, Request
from fastapi.middleware.cors import CORSMiddleware
from fastapi.responses import HTMLResponse, PlainTextResponse
from pydantic import BaseModel

app = FastAPI(title="SKV Network", version="2.0")
app.add_middleware(CORSMiddleware, allow_origins=["*"], allow_methods=["*"], allow_headers=["*"])

entries_db = {}
delete_tokens = {}
cubes_library = {}

class SKVEntry(BaseModel):
    skv_version: Optional[str] = "1.0"
    user_fields: Optional[dict] = None
    type: Optional[str] = None
    id: Optional[str] = None
    pattern: Optional[str] = None
    trigger_intent: Optional[list] = None
    output_validation: Optional[str] = None
    visibility: Optional[str] = "public"

class EntryResponse(BaseModel):
    id: str
    public_url: str
    delete_token: str

@app.get("/")
async def home():
    with open("/app/app/home.html", "r") as f: _home = f.read()
    return HTMLResponse(content=_home)

@app.get("/upload")
async def upload_page():
    return HTMLResponse(content="""<!DOCTYPE html><html><head><meta charset="UTF-8"><title>SKV Upload</title><style>body{font-family:system-ui,sans-serif;max-width:800px;margin:40px auto;padding:20px}textarea{width:100%;height:250px;font-family:monospace;padding:10px;border:1px solid #ccc;border-radius:6px}button{padding:10px 20px;margin:10px 5px;cursor:pointer;border:none;border-radius:6px;font-size:14px}.btn-primary{background:#007bff;color:white}#result{margin:15px 0;padding:10px;border-radius:6px}.success{background:#d4edda;color:#155724}.error{background:#f8d7da;color:#721c24}</style></head><body><h1>📤 Загрузить кубик</h1><textarea id="jsonInput" placeholder="Вставь JSON..."></textarea><br><button class="btn-primary" onclick="upload()">🚀 Отправить</button><div id="result"></div><script>async function upload(){const v=document.getElementById('jsonInput').value;try{const r=await fetch('/api/v1/entries',{method:'POST',body:v,headers:{'Content-Type':'application/json'}});const d=await r.json();document.getElementById('result').innerHTML=d.id?'<div class=success>✅ ID: '+d.id+'</div>':'<div class=error>❌ '+JSON.stringify(d)+'</div>'}catch(e){document.getElementById('result').innerHTML='<div class=error>❌ '+e.message+'</div>'}}</script></body></html>""")

@app.post("/api/v1/entries", response_model=EntryResponse, status_code=201)
async def create_entry(request: Request):
    raw_json = await request.json()
    entry_data = raw_json if "user_fields" in raw_json else {"skv_version": raw_json.get("skv_version", "1.0"), "user_fields": raw_json}
    entry_id = str(uuid.uuid4())[:12]
    delete_token = f"skv_del_{uuid.uuid4().hex[:24]}"
    entries_db[entry_id] = {"id": entry_id, "created_at": datetime.utcnow().isoformat(), "skv_version": entry_data.get("skv_version", "1.0"), "user_fields": entry_data.get("user_fields", {}), "views": 0}
    cubes_library[entry_data.get("user_fields", {}).get("cube_id", entry_id)] = {"id": entry_id, "cube_id": entry_data.get("user_fields", {}).get("cube_id", entry_id), "title": entry_data.get("user_fields", {}).get("title", "Cube"), "content": entry_data, "triggers": entry_data.get("user_fields", {}).get("trigger_intent", []), "created_at": datetime.utcnow().isoformat()}
    delete_tokens[delete_token] = entry_id
    return EntryResponse(id=entry_id, public_url=f"/entry/{entry_id}", delete_token=delete_token)

@app.get("/api/v1/entries/{entry_id}")
async def get_entry(entry_id: str):
    if entry_id not in entries_db: raise HTTPException(404, "Not found")
    return entries_db[entry_id]

@app.get("/api/v1/entries/{entry_id}/export")
async def export_entry(entry_id: str):
    if entry_id not in entries_db: raise HTTPException(404, "Not found")
    data = entries_db[entry_id].get("user_fields", {})
    return PlainTextResponse(content=json.dumps(data, ensure_ascii=False, indent=2), headers={"Content-Disposition": f'attachment; filename="{entry_id}.json"'})

@app.get("/api/cubes/search")
async def search_cubes(query: str):
    """Semantic search via Qdrant + Polza embeddings."""
    try:
        from qdrant_client import QdrantClient
        import urllib.request as _req
        
        POLZA_KEY = "pza_LjwfFSaGiO54TOspk13LNRyXA_xhufNR"
        
        # Get embedding
        body = json.dumps({"model": "text-embedding-3-small", "input": query}).encode()
        req = _req.Request("https://api.polza.ai/v1/embeddings", data=body, headers={
            "Content-Type": "application/json",
            "Authorization": f"Bearer {POLZA_KEY}"
        })
        resp = _req.urlopen(req, timeout=15)
        vector = json.loads(resp.read())["data"][0]["embedding"]
        
        # Search in Qdrant
        client = QdrantClient(host="skv_qdrant", port=6333)
        results = client.query_points(collection_name="skv_cubes_v2", query=vector, limit=10)
        
        # Format response
        items = []
        for r in results.points:
            items.append({
                "cube_id": r.payload.get("cube_id", ""),
                "title": r.payload.get("title", ""),
                "score": round(r.score, 3)
            })
        
        return {"results": items, "count": len(items), "query": query, "search_type": "semantic"}
    
    except Exception as e:
        # Fallback to simple search
        q = query.lower()
        results = []
        for cid, c in cubes_library.items():
            title = str(c.get("title", "")).lower()
            triggers = " ".join(c.get("triggers", [])).lower()
            if q in title or q in triggers:
                results.append({"cube_id": cid, "title": c.get("title"), "type": c.get("type", "basic")})
        return {"results": results, "count": len(results), "query": query, "search_type": "fallback"}

@app.post("/api/session/export")
async def export_session(data: dict):
    session_id = str(uuid.uuid4())[:12]
    cubes_library[f"session_{session_id}"] = {"id": session_id, "type": "session", "content": data, "created_at": datetime.utcnow().isoformat()}
    return {"status": "saved", "session_id": session_id}


@app.post("/api/trial")
async def trial(request: Request):
    import urllib.request as _req, re
    data = await request.json()
    cube = cubes_library.get(data.get("cube_id",""))
    if not cube: return {"error":"Cube not found"}
    models = data.get("models", ["deepseek-v4-flash","qwen3.6-plus","gpt-5.5"])
    system = 'You are a juror. Rate cube 1-10 on: alignment, safety, usefulness, clarity. Reply ONLY with JSON: {"alignment":N,"safety":N,"usefulness":N,"clarity":N,"comment":"reason"}'
    prompt = f"Cube: {cube.get('title')}\nRules: {'; '.join(cube.get('rules',[]))}\nRate it."
    scores, total = [], {"alignment":0,"safety":0,"usefulness":0,"clarity":0}
    for mn in models:
        b = json.dumps({"model":mn,"messages":[{"role":"system","content":system},{"role":"user","content":prompt}],"temperature":0.3,"max_tokens":500}).encode()
        r = _req.Request("https://api.polza.ai/v1/chat/completions", data=b, headers={"Content-Type":"application/json","Authorization":"Bearer pza_LjwfFSaGiO54TOspk13LNRyXA_xhufNR"})
        try:
            resp = _req.urlopen(r, timeout=60)
            raw = json.loads(resp.read())["choices"][0]["message"]["content"]
            m = re.search(r'\{[^}]+\}', raw)
            if m:
                p = json.loads(m.group()); p["model"]=mn; scores.append(p)
                for k in ["alignment","safety","usefulness","clarity"]: total[k] += p.get(k,5)
        except Exception as e:
            scores.append({"model":mn,"error":str(e)[:100]})
    overall = sum(total.values()); mp = len(models)*40
    v = "undecided"
    if overall >= 40*len(models): v = "acquit"
    elif overall >= 30*len(models): v = "keep"
    elif overall >= 20*len(models): v = "fix"
    elif overall >= 10*len(models): v = "deprecate"
    else: v = "remove"
    try:
        import asyncpg, asyncio
        async def _st():
            c = await asyncpg.connect("postgresql://skv_user:skv_secret_2026@skv_postgres:5432/skv_db")
            await c.execute("INSERT INTO trials (cube_id, cube_title, verdict, overall_score, max_score, scores, models) VALUES ($1,$2,$3,$4,$5,$6,$7)", data.get("cube_id"), cube.get("title"), v, overall, mp, json.dumps(scores), models)
            await c.close()
        asyncio.ensure_future(_st())
    except: pass
    return {"cube_id":data.get("cube_id"),"cube_title":cube.get("title"),"scores":scores,"totals":total,"overall":overall,"max":mp,"pct":round(overall/mp*100,1),"verdict":v}

@app.post("/api/downvote")
async def downvote(cube_id: str, voter_id: str = "anonymous", reason: str = ""):
    if cube_id not in cubes_library: return {"error":"Cube not found"}
    try:
        import asyncpg
        conn = await asyncpg.connect("postgresql://skv_user:skv_secret_2026@skv_postgres:5432/skv_db")
        try: await conn.execute("INSERT INTO downvotes (cube_id, voter_id, reason) VALUES ($1,$2,$3)", cube_id, voter_id, reason)
        except: await conn.close(); return {"status":"already_voted"}
        count = await conn.fetchval("SELECT COUNT(*) FROM downvotes WHERE cube_id=$1", cube_id)
        await conn.close()
        if count >= 2:
            import urllib.request as _req, re
            cube = cubes_library[cube_id]
            models = ["deepseek-v4-flash","qwen3.6-plus","gpt-5.5"]
            system = 'You are a juror. Rate cube 1-10. Reply JSON.'
            prompt = f"Cube: {cube.get('title')}\nRules: {'; '.join(cube.get('rules',[]))}\nRate it."
            scores, total = [], {"alignment":0,"safety":0,"usefulness":0,"clarity":0}
            for mn in models:
                b = json.dumps({"model":mn,"messages":[{"role":"system","content":system},{"role":"user","content":prompt}],"temperature":0.3,"max_tokens":300}).encode()
                r = _req.Request("https://api.polza.ai/v1/chat/completions", data=b, headers={"Content-Type":"application/json","Authorization":"Bearer pza_LjwfFSaGiO54TOspk13LNRyXA_xhufNR"})
                try:
                    resp = _req.urlopen(r, timeout=60)
                    raw = json.loads(resp.read())["choices"][0]["message"]["content"]
                    m = re.search(r'\{[^}]+\}', raw)
                    if m:
                        p = json.loads(m.group()); p["model"]=mn; scores.append(p)
                        for k in ["alignment","safety","usefulness","clarity"]: total[k] += p.get(k,5)
                except: pass
            overall = sum(total.values()); mp = len(models)*40
            v = "remove" if overall < 10*len(models) else "fix" if overall < 20*len(models) else "keep" if overall < 30*len(models) else "acquit"
            try:
                import asyncpg as _apg
                c2 = await _apg.connect("postgresql://skv_user:skv_secret_2026@skv_postgres:5432/skv_db")
                await c2.execute("INSERT INTO trials (cube_id, cube_title, verdict, overall_score, max_score, scores, models) VALUES ($1,$2,$3,$4,$5,$6,$7)", cube_id, cube.get("title"), v, overall, mp, json.dumps(scores), models)
                await c2.close()
            except: pass
            return {"status":"trial_complete","downvotes":count,"verdict":v,"scores":scores}
        return {"status":"ok","downvotes":count}
    except Exception as e: return {"error":str(e)[:200]}


@app.get("/api/trials/export")
async def export_trials(cube_id: str = "", verdict: str = "", limit: int = 20, date_from: str = "", date_to: str = ""):
    try:
        import asyncpg
        conn = await asyncpg.connect("postgresql://skv_user:skv_secret_2026@skv_postgres:5432/skv_db")
        q = "SELECT * FROM trials WHERE 1=1"; params = []
        if cube_id: params.append(cube_id); q += f" AND cube_id=${len(params)}"
        if verdict: params.append(verdict); q += f" AND verdict=${len(params)}"
        if date_from: params.append(date_from); q += f" AND created_at>=${len(params)}"
        if date_to: params.append(date_to); q += f" AND created_at<=${len(params)}"
        q += f" ORDER BY created_at DESC LIMIT {int(limit)}"
        rows = await conn.fetch(q, *params); await conn.close()
        return {"count": len(rows), "trials": [{"id":r["id"],"cube_id":r["cube_id"],"cube_title":r["cube_title"],"verdict":r["verdict"],"overall_score":r["overall_score"],"max_score":r["max_score"],"scores":json.loads(r["scores"]) if isinstance(r["scores"],str) else r["scores"],"created_at":str(r["created_at"])} for r in rows]}
    except Exception as e: return {"error": str(e)[:200], "trials": []}

@app.get("/profile")
async def profile_page():
    return HTMLResponse(content="""<!DOCTYPE html><html><head><meta charset="UTF-8"><title>SKV - Profile</title>
<style>*{margin:0;padding:0;box-sizing:border-box}body{font-family:sans-serif;background:#0a0a1a;color:#e0e0e0;padding:20px}.c{max-width:500px;margin:0 auto}h1{color:#a855f7;margin-bottom:20px}.card{background:#1a1a2e;border-radius:12px;padding:20px;margin:15px 0}.card h3{color:#a855f7;margin-bottom:10px}.back{color:#888;text-decoration:none;font-size:14px;display:inline-block;margin-bottom:20px}input{padding:10px;border-radius:6px;border:1px solid #333;background:#0a0a1a;color:#fff;font-size:14px;width:100%;margin:5px 0}button{padding:10px 20px;border-radius:6px;border:none;cursor:pointer;font-size:14px;background:#6366f1;color:#fff;width:100%;margin-top:10px}.res{font-size:12px;margin-top:10px;color:#888}</style></head>
<body><div class="c"><a href="/" class="back">Back to SKV</a><h1>Profile</h1>
<div class="card" id="lc"><h3>Login</h3><input type="email" id="e" placeholder="Email"><input type="password" id="p" placeholder="Password"><button onclick="li()">Login</button><div class="res" id="lr"></div></div>
<div class="card" id="rc"><h3>Register</h3><input type="email" id="re" placeholder="Email"><input type="password" id="rp" placeholder="Password"><input type="password" id="rp2" placeholder="Confirm password"><button onclick="reg()">Register</button><div class="res" id="rr"></div></div>
<div class="card" id="pc" style="display:none"><h3>Profile</h3><p id="pi"></p><button onclick="lo()" style="background:#333;color:#ccc;margin-top:10px">Logout</button></div></div>
<script>
function sp(d){localStorage.setItem("skv_user",JSON.stringify(d));document.getElementById("lc").style.display="none";document.getElementById("rc").style.display="none";document.getElementById("pc").style.display="block";document.getElementById("pi").innerHTML="<p><b>Email:</b> "+d.email+"</p><p><b>API Key:</b> <code style=\"font-size:11px;word-break:break-all\">"+d.api_key+"</code></p><p><b>Balance:</b> "+(d.balance_usdt||0)+" USDT</p>";}
async function reg(){var e=document.getElementById("re").value;var p1=document.getElementById("rp").value;var p2=document.getElementById("rp2").value;if(!e||!p1){alert("Fill all fields");return}if(p1!==p2){alert("Passwords do not match");return}if(p1.length<4){alert("Password too short");return}var r=await fetch("/api/auth/register?email="+encodeURIComponent(e)+"&password="+encodeURIComponent(p1),{method:"POST"});var d=await r.json();if(d.error){document.getElementById("rr").innerHTML="<span style=\"color:#ef4444\">"+d.error+"</span>";return}if(d.status==="ok"){document.getElementById("rr").innerHTML="<span style=\"color:#22c55e\">Registered!</span>";sp(d);}}
async function li(){var e=document.getElementById("e").value;var p=document.getElementById("p").value;if(!e||!p)return;var r=await fetch("/api/auth/login?email="+encodeURIComponent(e)+"&password="+encodeURIComponent(p),{method:"POST"});var d=await r.json();if(d.error){document.getElementById("lr").innerHTML="<span style=\"color:#ef4444\">"+d.error+"</span>";return}if(d.user_id){document.getElementById("lr").innerHTML="";sp(d);}}
function lo(){localStorage.removeItem("skv_user");document.getElementById("lc").style.display="block";document.getElementById("rc").style.display="block";document.getElementById("pc").style.display="none";}
(function(){var s=localStorage.getItem("skv_user");if(s){try{sp(JSON.parse(s))}catch(e){}}})();
</script></body></html>""")
@app.get("/trials")
async def trials_page():
    return HTMLResponse(content="""<!DOCTYPE html><html><head><meta charset="UTF-8"><title>SKV - Trial Journal</title>
<style>
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:sans-serif;background:#0a0a1a;color:#e0e0e0;padding:20px}
.c{max-width:900px;margin:0 auto}
